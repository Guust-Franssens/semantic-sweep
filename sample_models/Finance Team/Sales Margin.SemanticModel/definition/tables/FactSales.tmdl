table FactSales

	column OrderDate
		dataType: dateTime
		summarizeBy: none

	column ProductKey
		dataType: int64
		summarizeBy: none

	column Amount
		dataType: double
		summarizeBy: none

	column Cost
		dataType: double
		summarizeBy: none

	partition FactSales = entity
		mode: directLake
		source
			entityName: FactSales
			schemaName: dbo
