table Sales

	column OrderDate
		dataType: dateTime
		summarizeBy: none

	column ProductKey
		dataType: int64
		summarizeBy: none

	column Revenue
		dataType: double
		summarizeBy: none

	column Units
		dataType: int64
		summarizeBy: none

	partition Sales = entity
		mode: directLake
		source
			entityName: Sales
			schemaName: dbo
