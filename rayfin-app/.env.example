# semantic-sweep - Rayfin Fabric App environment
#
# Copy this file to `.env.local` and fill in the two Entra values below. Everything else is written
# for you by `rayfin up` / `rayfin env --framework vite` (workspace id, item id, publishable key,
# API url), so do not hand-edit those.

# --- You set these: the Entra SPA app registration used to acquire the Power BI scan token ---
# Application (client) ID of your Entra single-page-application registration. See README.md step 1.
VITE_FABRIC_SPA_CLIENT_ID=
# Directory (tenant) ID the app registration lives in.
VITE_FABRIC_SPA_TENANT=

# --- Optional ---
# Preview the UI locally with bundled sample data and no backend / no sign-in:
#   VITE_SS_LOCAL_PREVIEW=1 npm run dev:local
# Leave unset for normal Fabric-authenticated runs.
# VITE_SS_LOCAL_PREVIEW=1

# --- Auto-managed by Rayfin (listed for reference only; do not set these by hand) ---
# VITE_RAYFIN_API_URL=
# VITE_RAYFIN_PUBLISHABLE_KEY=
# VITE_FABRIC_WORKSPACE_ID=
# VITE_FABRIC_ITEM_ID=
# VITE_FABRIC_PORTAL_URL=
