table DimWarehouse

	column WarehouseKey
		dataType: int64
		summarizeBy: none
		sourceColumn: WarehouseKey

	column WarehouseName
		dataType: string
		summarizeBy: none
		sourceColumn: WarehouseName

	column Region
		dataType: string
		summarizeBy: none
		sourceColumn: Region

	partition DimWarehouse = entity
		mode: directQuery
		source
			entityName: DimWarehouse
			expressionSource: DatabaseQuery
