table FactShipments

	column ShipDate
		dataType: dateTime
		summarizeBy: none
		sourceColumn: ShipDate

	column WarehouseKey
		dataType: int64
		summarizeBy: none
		sourceColumn: WarehouseKey

	column Cost
		dataType: double
		summarizeBy: sum
		sourceColumn: Cost

	column WeightKg
		dataType: double
		summarizeBy: sum
		sourceColumn: WeightKg

	column Shipments
		dataType: int64
		summarizeBy: sum
		sourceColumn: Shipments

	partition FactShipments = entity
		mode: directQuery
		source
			entityName: FactShipments
			expressionSource: DatabaseQuery
