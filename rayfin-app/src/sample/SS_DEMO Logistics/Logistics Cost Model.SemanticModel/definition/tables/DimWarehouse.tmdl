table DimWarehouse

	column WarehouseKey
		dataType: int64
		summarizeBy: none
		sourceColumn: WarehouseKey

	column WarehouseName
		dataType: string
		summarizeBy: none
		sourceColumn: WarehouseName

	column Region
		dataType: string
		summarizeBy: none
		sourceColumn: Region

	partition DimWarehouse = m
		mode: import
		source =
			let
				Source = #table(type table [WarehouseKey = Int64.Type, WarehouseName = text, Region = text], {{1, "Antwerp DC", "EU-West"}})
			in
				Source
