table DimDate

	column Date
		dataType: dateTime
		summarizeBy: none
		sourceColumn: Date

	column Year
		dataType: int64
		summarizeBy: none
		sourceColumn: Year

	column MonthName
		dataType: string
		summarizeBy: none
		sourceColumn: MonthName

	partition DimDate = m
		mode: import
		source =
			let
				Source = #table(type table [Date = date, Year = Int64.Type, MonthName = text], {{#date(2024,1,1), 2024, "January"}})
			in
				Source
