table Sales

	column OrderDate
		dataType: dateTime
		summarizeBy: none
		sourceColumn: OrderDate

	column SkuKey
		dataType: int64
		summarizeBy: none
		sourceColumn: SkuKey

	column Hectolitres
		dataType: double
		summarizeBy: none
		sourceColumn: Hectolitres

	column Turnover
		dataType: double
		summarizeBy: none
		sourceColumn: Turnover

	partition Sales = m
		mode: import
		source =
			let
				Source = #table(type table [OrderDate = date, SkuKey = Int64.Type, Hectolitres = number, Turnover = number], {{#date(2024,1,1), 1, 1250.0, 84000.0}})
			in
				Source
